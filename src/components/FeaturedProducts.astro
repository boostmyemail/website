---
import { getCollection } from 'astro:content';

const products = (await getCollection('products'))
  .filter(p => p.data.featured)
  .sort((a, b) => (a.data.sort_order ?? 99) - (b.data.sort_order ?? 99));
---

<section class="featured-products">
  <div class="inner">
    <div class="header">
      <div>
        <span class="eyebrow">Featured products</span>
        <h2>Audits, consulting, and playbooks for B2B SaaS email.</h2>
      </div>
      <a href={`${import.meta.env.BASE_URL}products/`} class="view-all">View all →</a>
    </div>
    <div class="grid">
      {products.map(p => (
        <article class="card">
          <div class="card-top">
            <span class="price-badge">{p.data.price_label}</span>
            {p.data.badge && <span class="popular-badge">{p.data.badge}</span>}
          </div>
          <h3>{p.data.title}</h3>
          <p>{p.data.tagline}</p>
          <div class="card-cta">
            <a href={`${import.meta.env.BASE_URL}products/${p.id}/`} class="btn-primary">
              Learn more
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .featured-products {
    padding: 96px 32px;
  }

  .inner {
    max-width: var(--width-page);
    margin: 0 auto;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 40px;
    gap: 24px;
    flex-wrap: wrap;
  }

  .eyebrow {
    display: block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 14px;
  }

  h2 {
    font-size: clamp(28px, 3vw, 36px);
    letter-spacing: -0.01em;
    max-width: 620px;
  }

  .view-all {
    font-size: 13px;
    color: rgba(255,255,255,0.45);
    white-space: nowrap;
    transition: color .15s ease;
    letter-spacing: -0.005em;
    flex-shrink: 0;
  }
  .view-all:hover { color: #fff; }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
  }

  .card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 12px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    box-shadow: var(--shadow-card);
    transition: background .15s ease;
  }

  .card:hover {
    background: rgba(255,255,255,0.09);
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .price-badge {
    display: inline-flex;
    align-items: center;
    background: var(--accent);
    color: #fff;
    border-radius: 999px;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .popular-badge {
    display: inline-flex;
    align-items: center;
    background: rgba(161,1,0,0.20);
    color: rgba(255,180,180,0.90);
    border: 1px solid rgba(161,1,0,0.35);
    border-radius: 999px;
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  h3 {
    font-size: 22px;
    letter-spacing: -0.005em;
    line-height: 1.25;
    margin-top: 4px;
  }

  p {
    font-size: 15px;
    color: rgba(255,255,255,0.60);
    line-height: 1.6;
    flex: 1;
    text-wrap: pretty;
    margin: 0;
  }

  .card-cta {
    margin-top: 8px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: #fff;
    border-radius: var(--r-pill);
    padding: 12px 24px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
    transition: background .15s ease, transform .1s ease;
  }

  .btn-primary:hover { background: var(--accent-hover); color: #fff; }
  .btn-primary:active { transform: translateY(1px); }
</style>
