---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout
  title="Lifecycle Operator — Boost My Email Blog"
  description="Tactics and frameworks from the execution layer of B2B SaaS email."
>
  <section class="blog-header">
    <div class="container">
      <span class="eyebrow">Blog</span>
      <h1>Lifecycle Operator</h1>
      <p class="tagline">Tactics and frameworks from the execution layer of B2B SaaS email.</p>
    </div>
  </section>

  <section class="post-list">
    <div class="container">
      {posts.length === 0 ? (
        <p class="empty">No posts yet. Check back soon.</p>
      ) : (
        <ul>
          {posts.map(post => (
            <li class="post-item">
              <a href={`${import.meta.env.BASE_URL}blog/${post.id}/`} class="post-link">
                <div class="post-meta">
                  <time datetime={post.data.date.toISOString()}>
                    {formatDate(post.data.date)}
                  </time>
                </div>
                <h2 class="post-title">{post.data.title}</h2>
                {post.data.description && (
                  <p class="post-excerpt">{post.data.description}</p>
                )}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</Layout>

<style>
  .container {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .blog-header {
    padding: 88px 0 56px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .eyebrow {
    display: block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 16px;
  }

  h1 {
    font-size: clamp(32px, 4vw, 48px);
    letter-spacing: -0.015em;
    margin-bottom: 14px;
  }

  .tagline {
    font-size: 17px;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
    max-width: 540px;
    margin: 0;
  }

  .post-list {
    padding: 16px 0 96px;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-item {
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .post-link {
    display: block;
    padding: 36px 0;
    color: inherit;
    transition: none;
  }

  .post-link:hover .post-title {
    color: var(--accent);
  }

  .post-meta {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 10px;
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: clamp(18px, 2.2vw, 24px);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--fg1);
    margin: 0 0 10px 0;
    transition: color .15s ease;
  }

  .post-excerpt {
    font-size: 15px;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
    margin: 0;
    max-width: 600px;
    text-wrap: pretty;
  }

  .empty {
    padding: 48px 0;
    color: rgba(255,255,255,0.35);
    font-size: 15px;
  }
</style>
