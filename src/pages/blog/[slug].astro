---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout
  title={`${post.data.title} — Lifecycle Operator`}
  description={post.data.description}
>
  <article class="post">
    <header class="post-header">
      <div class="container">
        <a href={`${import.meta.env.BASE_URL}blog/`} class="back-link">← Blog</a>
        <div class="post-meta">
          <time datetime={post.data.date.toISOString()}>
            {formatDate(post.data.date)}
          </time>
        </div>
        <h1>{post.data.title}</h1>
        {post.data.description && (
          <p class="post-deck">{post.data.description}</p>
        )}
      </div>
    </header>

    {post.data.image && (
      <div class="hero-image-wrap">
        <div class="container">
          <img src={post.data.image} alt="" class="hero-image" />
        </div>
      </div>
    )}

    <div class="post-body container">
      <Content />
    </div>

    <footer class="post-footer">
      <div class="container">
        <a href={`${import.meta.env.BASE_URL}blog/`} class="back-link">← Back to blog</a>
      </div>
    </footer>
  </article>
</Layout>

<style>
  .container {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ── Header ── */
  .post-header {
    padding: 64px 0 40px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .back-link {
    display: inline-block;
    font-size: 13px;
    color: rgba(255,255,255,0.40);
    margin-bottom: 28px;
    transition: color .15s ease;
    letter-spacing: -0.005em;
  }
  .back-link:hover { color: rgba(255,255,255,0.75); }

  .post-meta {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 16px;
  }

  h1 {
    font-size: clamp(28px, 4vw, 42px);
    letter-spacing: -0.015em;
    line-height: 1.15;
    margin-bottom: 18px;
    text-wrap: balance;
  }

  .post-deck {
    font-size: 18px;
    color: rgba(255,255,255,0.60);
    line-height: 1.6;
    margin: 0;
    text-wrap: pretty;
  }

  /* ── Hero image ── */
  .hero-image-wrap {
    padding: 36px 0 0;
  }
  .hero-image {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
  }

  /* ── Body ── */
  .post-body {
    padding: 52px 32px 80px;
    font-size: 16px;
    line-height: 1.75;
    color: rgba(255,255,255,0.80);
  }

  .post-body :global(h2) {
    font-family: var(--font-heading);
    font-size: clamp(20px, 2.5vw, 26px);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--fg1);
    margin: 48px 0 16px;
    line-height: 1.25;
  }

  .post-body :global(h3) {
    font-family: var(--font-heading);
    font-size: clamp(17px, 2vw, 20px);
    font-weight: 500;
    letter-spacing: -0.005em;
    color: var(--fg1);
    margin: 36px 0 12px;
    line-height: 1.3;
  }

  .post-body :global(p) {
    margin: 0 0 24px;
    color: rgba(255,255,255,0.75);
  }

  .post-body :global(a) {
    color: #fff;
    text-decoration: underline;
    text-decoration-color: rgba(255,255,255,0.30);
    text-underline-offset: 3px;
    transition: text-decoration-color .15s ease;
  }
  .post-body :global(a:hover) {
    text-decoration-color: var(--accent);
    color: #fff;
  }

  .post-body :global(strong) { color: var(--fg1); font-weight: 500; }
  .post-body :global(em) { font-style: italic; }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 0 0 24px;
    padding-left: 24px;
    color: rgba(255,255,255,0.75);
  }
  .post-body :global(li) { margin-bottom: 8px; line-height: 1.65; }
  .post-body :global(li::marker) { color: var(--accent); }

  .post-body :global(blockquote) {
    border-left: 2px solid var(--accent);
    background: rgba(161,1,0,0.08);
    margin: 32px 0;
    padding: 18px 22px;
    border-radius: 0 8px 8px 0;
  }
  .post-body :global(blockquote p) {
    font-style: italic;
    color: rgba(255,255,255,0.75);
    margin: 0;
    font-size: 16px;
  }

  .post-body :global(pre) {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 8px;
    padding: 20px 24px;
    overflow-x: auto;
    margin: 28px 0;
    font-size: 13px;
    line-height: 1.65;
  }
  .post-body :global(code) {
    font-family: 'Fira Code', 'Cascadia Code', 'Consolas', monospace;
    font-size: 0.88em;
    color: rgba(255,255,255,0.85);
  }
  .post-body :global(pre code) {
    font-size: 13px;
    color: rgba(255,255,255,0.80);
  }
  .post-body :global(:not(pre) > code) {
    background: rgba(255,255,255,0.08);
    border-radius: 4px;
    padding: 2px 6px;
    font-size: 0.88em;
  }

  .post-body :global(img) {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
    margin: 32px 0 8px;
  }

  .post-body :global(figure) {
    margin: 32px 0;
  }
  .post-body :global(figure img) { margin: 0 0 10px; }
  .post-body :global(figcaption) {
    font-size: 13px;
    color: rgba(255,255,255,0.35);
    line-height: 1.5;
    text-align: center;
  }

  /* Responsive YouTube / iframe embeds */
  .post-body :global(.youtube),
  .post-body :global(iframe) {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: none;
    border-radius: 8px;
    display: block;
    margin: 32px 0;
  }
  .post-body :global(.youtube-wrap) {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 32px 0;
  }
  .post-body :global(.youtube-wrap iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.08);
    margin: 48px 0;
  }

  /* ── Footer ── */
  .post-footer {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 32px 0 64px;
  }
</style>
