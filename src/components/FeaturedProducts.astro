---
const products = [
  {
    price: "$297",
    title: "The SaaS Activation Blueprint",
    desc: "Map every lifecycle email to a product milestone.",
  },
  {
    price: "$397",
    title: "The Lifecycle Revenue Dashboard",
    desc: "Show leadership what email actually produces.",
  },
  {
    price: "$497",
    title: "The PQL Conversion Playbook",
    desc: "Turn product signals into pipeline.",
  },
];
---

<section class="featured-products">
  <div class="inner">
    <div class="header">
      <div>
        <span class="eyebrow">Featured products</span>
        <h2>Playbooks built from real B2B SaaS programs.</h2>
      </div>
    </div>
    <div class="grid">
      {products.map(p => (
        <article class="card">
          <div>
            <span class="price-badge">{p.price}</span>
          </div>
          <h3>{p.title}</h3>
          <p>{p.desc}</p>
          <div class="card-cta">
            <a href="#" class="btn-primary">Get it</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .featured-products {
    padding: 96px 32px;
  }

  .inner {
    max-width: var(--width-page);
    margin: 0 auto;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 40px;
    gap: 24px;
    flex-wrap: wrap;
  }

  .eyebrow {
    display: block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 14px;
  }

  h2 {
    font-size: clamp(28px, 3vw, 36px);
    letter-spacing: -0.01em;
    max-width: 620px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 12px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    box-shadow: 0 1px 0 rgba(255,255,255,0.04) inset;
    transition: background .15s ease;
  }

  .card:hover {
    background: rgba(255,255,255,0.09);
  }

  .price-badge {
    display: inline-flex;
    align-items: center;
    background: var(--accent);
    color: #fff;
    border-radius: 999px;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  h3 {
    font-size: 22px;
    letter-spacing: -0.005em;
    line-height: 1.25;
    margin-top: 4px;
  }

  p {
    font-size: 15px;
    color: rgba(255,255,255,0.60);
    line-height: 1.6;
    flex: 1;
    text-wrap: pretty;
  }

  .card-cta {
    margin-top: 8px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: #fff;
    border-radius: var(--r-pill);
    padding: 12px 24px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
    transition: background .15s ease, transform .1s ease;
  }

  .btn-primary:hover {
    background: var(--accent-hover);
    color: #fff;
  }

  .btn-primary:active {
    transform: translateY(1px);
  }

  @media (max-width: 760px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
