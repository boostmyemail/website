---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);

const categoryLabel: Record<string, string> = {
  'done-for-you': 'Done For You',
  'consulting': 'Consulting',
  'digital': 'Digital',
};
---

<Layout
  title={`${product.data.title} — Boost My Email`}
  description={product.data.tagline}
>
  <article class="product">

    <header class="product-header">
      <div class="container">
        <a href={`${import.meta.env.BASE_URL}products/`} class="back-link">← Products</a>
        <div class="meta-row">
          <span class="category-badge">{categoryLabel[product.data.category]}</span>
          {product.data.badge && (
            <span class="popular-badge">{product.data.badge}</span>
          )}
        </div>
        <h1>{product.data.title}</h1>
        <p class="deck">{product.data.tagline}</p>
        {product.data.available_for && (
          <p class="availability">
            Available for <strong>{product.data.available_for.join(' and ')}</strong> customers only.
          </p>
        )}
        <div class="header-cta">
          <span class="price">{product.data.price_label}</span>
          <a
            href={product.data.cta_url}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            {product.data.cta_label}
          </a>
        </div>
      </div>
    </header>

    <div class="product-body container">
      <Content />
    </div>

    <section class="closing-cta">
      <div class="container container-narrow">
        <h2>Ready to get started?</h2>
        <p>Book a call and we'll figure out if it's the right fit.</p>
        <a
          href={product.data.cta_url}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary btn-large"
        >
          {product.data.cta_label}
        </a>
      </div>
    </section>

    <footer class="product-footer">
      <div class="container">
        <a href={`${import.meta.env.BASE_URL}products/`} class="back-link">← Back to products</a>
      </div>
    </footer>

  </article>
</Layout>

<style>
  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .container-narrow {
    max-width: 560px;
  }

  /* ── Header ── */
  .product-header {
    padding: 64px 0 48px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .back-link {
    display: inline-block;
    font-size: 13px;
    color: rgba(255,255,255,0.40);
    margin-bottom: 28px;
    transition: color .15s ease;
    letter-spacing: -0.005em;
  }
  .back-link:hover { color: rgba(255,255,255,0.75); }

  .meta-row {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }

  .category-badge {
    display: inline-flex;
    align-items: center;
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.55);
    border-radius: var(--r-pill);
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .popular-badge {
    display: inline-flex;
    align-items: center;
    background: rgba(161,1,0,0.20);
    color: rgba(255,180,180,0.90);
    border: 1px solid rgba(161,1,0,0.35);
    border-radius: var(--r-pill);
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  h1 {
    font-size: clamp(28px, 4vw, 44px);
    letter-spacing: -0.015em;
    line-height: 1.15;
    margin-bottom: 16px;
    text-wrap: balance;
  }

  .deck {
    font-size: 18px;
    color: rgba(255,255,255,0.60);
    line-height: 1.6;
    margin-bottom: 20px;
    text-wrap: pretty;
  }

  .availability {
    font-size: 13px;
    color: rgba(255,255,255,0.40);
    margin-bottom: 32px;
    padding: 10px 14px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--r-md);
    display: inline-block;
  }
  .availability strong { color: rgba(255,255,255,0.70); font-weight: 500; }

  .header-cta {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    margin-top: 32px;
  }

  .price {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 500;
    color: #fff;
    letter-spacing: -0.02em;
  }

  /* ── Buttons ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: #fff;
    border-radius: var(--r-pill);
    padding: 13px 28px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
    transition: background .15s ease, transform .1s ease;
  }
  .btn-primary:hover { background: var(--accent-hover); color: #fff; }
  .btn-primary:active { transform: translateY(1px); }
  .btn-large { padding: 16px 36px; font-size: 16px; }

  /* ── Body prose ── */
  .product-body {
    padding: 52px 32px 80px;
    font-size: 16px;
    line-height: 1.75;
    color: rgba(255,255,255,0.80);
  }

  .product-body :global(h2) {
    font-family: var(--font-heading);
    font-size: clamp(20px, 2.5vw, 26px);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--fg1);
    margin: 52px 0 16px;
    line-height: 1.25;
  }
  .product-body :global(h2:first-child) { margin-top: 0; }

  .product-body :global(h3) {
    font-family: var(--font-heading);
    font-size: clamp(16px, 2vw, 19px);
    font-weight: 500;
    letter-spacing: -0.005em;
    color: var(--fg1);
    margin: 36px 0 10px;
    line-height: 1.3;
  }

  .product-body :global(p) {
    margin: 0 0 22px;
    color: rgba(255,255,255,0.75);
  }

  .product-body :global(a) {
    color: #fff;
    text-decoration: underline;
    text-decoration-color: rgba(255,255,255,0.30);
    text-underline-offset: 3px;
    transition: text-decoration-color .15s ease;
  }
  .product-body :global(a:hover) {
    text-decoration-color: var(--accent);
    color: #fff;
  }

  .product-body :global(strong) { color: var(--fg1); font-weight: 500; }
  .product-body :global(em) { font-style: italic; }

  .product-body :global(ul), .product-body :global(ol) {
    margin: 0 0 22px;
    padding-left: 24px;
    color: rgba(255,255,255,0.75);
  }
  .product-body :global(li) { margin-bottom: 8px; line-height: 1.65; }
  .product-body :global(li::marker) { color: var(--accent); }

  .product-body :global(blockquote) {
    border-left: 2px solid var(--accent);
    background: rgba(161,1,0,0.08);
    margin: 32px 0;
    padding: 18px 22px;
    border-radius: 0 8px 8px 0;
  }
  .product-body :global(blockquote p) {
    font-style: italic;
    color: rgba(255,255,255,0.75);
    margin: 0;
  }

  .product-body :global(hr) {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.08);
    margin: 48px 0;
  }

  /* ── Closing CTA ── */
  .closing-cta {
    background: rgba(161,1,0,0.10);
    border-top: 1px solid rgba(161,1,0,0.25);
    border-bottom: 1px solid rgba(161,1,0,0.25);
    padding: 72px 32px;
    text-align: center;
  }
  .closing-cta h2 {
    font-size: clamp(22px, 3vw, 30px);
    letter-spacing: -0.01em;
    margin-bottom: 12px;
  }
  .closing-cta p {
    font-size: 16px;
    color: rgba(255,255,255,0.60);
    margin-bottom: 32px;
  }

  /* ── Footer ── */
  .product-footer {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 32px 0 64px;
  }
</style>
