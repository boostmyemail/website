---
interface Props {
  id: string;
  title?: string;
}
const { id, title = "YouTube video" } = Astro.props;
---

<div class="youtube-wrap">
  <iframe
    src={`https://www.youtube-nocookie.com/embed/${id}`}
    title={title}
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
  ></iframe>
</div>

<style>
  .youtube-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 32px 0;
    border-radius: 8px;
    overflow: hidden;
  }
  iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>
